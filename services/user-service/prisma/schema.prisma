generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  username    String    @unique @db.VarChar(50)
  displayName String    @map("display_name") @db.VarChar(100)
  bio         String?   @db.Text
  avatarUrl   String?   @map("avatar_url") @db.Text
  phone       String?   @db.VarChar(20)
  isOnline    Boolean   @default(false) @map("is_online")
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz(6)
  statusMsg   String?   @map("status_msg") @db.VarChar(200)
  privacy     Json      @default("{\"last_seen\":\"contacts\",\"profile_photo\":\"everyone\"}") @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  contacts    Contact[]     @relation("ContactOwner")
  contactOf   Contact[]     @relation("ContactTarget")
  blocking    BlockedUser[] @relation("Blocker")
  blockedBy   BlockedUser[] @relation("Blocked")

  @@map("users")
}

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @map("owner_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  nickname  String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner   User @relation("ContactOwner", fields: [ownerId], references: [id])
  contact User @relation("ContactTarget", fields: [contactId], references: [id])

  @@unique([ownerId, contactId])
  @@map("contacts")
}

model BlockedUser {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
  @@map("blocked_users")
}
